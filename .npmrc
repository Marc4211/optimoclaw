# Block postinstall scripts from dependencies to prevent supply chain attacks.
# This is a zero-cost safeguard against compromised packages that use
# postinstall lifecycle scripts to execute malicious code.
#
# If a legitimate package needs a postinstall script (e.g. esbuild, sharp),
# explicitly allow it:
#   npx npm-exec --package=sharp -- npm run postinstall
ignore-scripts=true
